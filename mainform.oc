// Main form

// Global variables
Draw draw;
int gridSize;
bool soundEnabled = false;


handler mainForm.onopen() {
	draw.attachForm(this);
	
	push16px.checked = true;
}


handler mainForm.ondraw() {

}


handler newCanvasButton.onselect() {
	if (push16px.checked)
		gridSize = 16;
	else
		gridSize = 32;

	canvasForm.load();
}
